{% comment %}
  =============================================================================
  c_image-asymmetry.liquid
  =============================================================================
  作成日: 2026-06-27
  作成者: s.tamaki (Devin)

  目的:
    参考サイト（https://panio2014.com/）に近づけるための
    アシンメトリー（非対称）画像レイアウトセクション。
    左右で異なるサイズの画像を配置し、テキスト・リンクと組み合わせる
    ビジュアルセクション。トップページの中盤に配置することを想定。

  変更履歴:
    2026-06-27 - 初回作成。2画像+テキストのアシンメトリーレイアウトを実装。
  =============================================================================
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ section.settings.horizontal_padding }}px;
    padding-right: {{ section.settings.horizontal_padding }}px;
    max-width: 100%;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .page-width.section-{{ section.id }}-padding {
    margin-left: auto !important;
    margin-right: auto !important;
    max-width: 100% !important;
  }

  .c-image-asymmetry {
    display: grid;
    gap: {{ section.settings.gap }}px;
  }

  @media screen and (min-width: 750px) {
    .c-image-asymmetry {
      grid-template-columns: {{ section.settings.left_ratio }}fr {{ section.settings.right_ratio }}fr;
      align-items: {{ section.settings.alignment }};
    }
  }

  .c-image-asymmetry__media {
    position: relative;
    overflow: hidden;
  }

  .c-image-asymmetry__media img,
  .c-image-asymmetry__media svg {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .c-image-asymmetry__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    {% if section.settings.text_background_color != blank %}
      background-color: {{ section.settings.text_background_color }};
    {% endif %}
    padding: {{ section.settings.content_padding }}px;
  }

  .c-image-asymmetry__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: {{ section.settings.heading_size }}px;
    color: rgb(var(--color-foreground));
    margin: 0 0 1.2rem {{ section.settings.heading_indent }}px;
    letter-spacing: 0.04rem;
    line-height: 1.3;
  }

  .c-image-asymmetry__text {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    font-size: {{ section.settings.text_size }}px;
    color: rgb(var(--color-foreground));
    line-height: 1.7;
    margin: 0 0 1.6rem;
  }

  .c-image-asymmetry__button {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    display: inline-block;
    padding: 0.8rem 2.4rem;
    border: 1px solid rgb(var(--color-foreground));
    color: rgb(var(--color-foreground));
    background: transparent;
    text-decoration: none;
    font-size: 1.4rem;
    transition: background 0.2s ease, color 0.2s ease;
    align-self: flex-start;
  }

  .c-image-asymmetry__button:hover {
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding c-image-asymmetry-wrapper">
    <div class="c-image-asymmetry">
      {%- if section.settings.image_1 != blank -%}
        <div class="c-image-asymmetry__media">
          <img
            src="{{ section.settings.image_1 | image_url: width: 1500 }}"
            srcset="
              {{ section.settings.image_1 | image_url: width: 400 }} 400w,
              {{ section.settings.image_1 | image_url: width: 800 }} 800w,
              {{ section.settings.image_1 | image_url: width: 1200 }} 1200w,
              {{ section.settings.image_1 | image_url: width: 1500 }} 1500w
            "
            sizes="(min-width: 750px) 60vw, 100vw"
            alt="{{ section.settings.image_1.alt | escape }}"
            width="{{ section.settings.image_1.width }}"
            height="{{ section.settings.image_1.height }}"
            loading="lazy"
          >
        </div>
      {%- else -%}
        <div class="c-image-asymmetry__media">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      <div class="c-image-asymmetry__content">
        {%- if section.settings.image_2 != blank -%}
          <div class="c-image-asymmetry__media" style="margin-bottom: 2.4rem;">
            <img
              src="{{ section.settings.image_2 | image_url: width: 800 }}"
              srcset="
                {{ section.settings.image_2 | image_url: width: 300 }} 300w,
                {{ section.settings.image_2 | image_url: width: 600 }} 600w,
                {{ section.settings.image_2 | image_url: width: 800 }} 800w
              "
              sizes="(min-width: 750px) 40vw, 100vw"
              alt="{{ section.settings.image_2.alt | escape }}"
              width="{{ section.settings.image_2.width }}"
              height="{{ section.settings.image_2.height }}"
              loading="lazy"
            >
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="c-image-asymmetry__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="c-image-asymmetry__text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <a href="{{ section.settings.button_link }}" class="c-image-asymmetry__button">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "★ アシンメトリー画像",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "画像設定"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "メイン画像（左・大）"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "サブ画像（右・小）"
    },
    {
      "type": "header",
      "content": "テキスト設定"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Heading",
      "label": "見出し"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "見出しフォントサイズ",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_indent",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "見出しの左余白",
      "default": 0
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>説明文をここに入力します。</p>",
      "label": "本文"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "本文フォントサイズ",
      "default": 14
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "View More",
      "label": "ボタンラベル"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク先"
    },
    {
      "type": "header",
      "content": "レイアウト設定"
    },
    {
      "type": "range",
      "id": "left_ratio",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "左カラム比率",
      "default": 2
    },
    {
      "type": "range",
      "id": "right_ratio",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "右カラム比率",
      "default": 1
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "画像間の隙間",
      "default": 16
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "垂直方向の揃え",
      "options": [
        { "value": "start", "label": "上" },
        { "value": "center", "label": "中央" },
        { "value": "end", "label": "下" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "テキスト側の内側余白",
      "default": 0
    },
    {
      "type": "color",
      "id": "text_background_color",
      "label": "テキスト側の背景色",
      "default": "#ffffff"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラースキーム",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "余白設定"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上余白",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下余白",
      "default": 40
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "左右余白（セクション全体）",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "★ アシンメトリー画像"
    }
  ]
}
{% endschema %}
